{
  "name": "btravstack-web",
  "private": true,
  "type": "module",
  "description": "btravstack website + shared VitePress theme (turborepo)",
  "license": "MIT",
  "author": "Benoit TRAVERS",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.19"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "preview": "turbo run preview",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter=@btravstack/theme && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "turbo": "2.10.0"
  }
}
